{
  "expo": {
    "name": "AlbTurf Mobile",
    "slug": "albturf-mobile",
    "scheme": "albturf",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.albturf.mobile" },
